              "const data = { code: pm.response.code, status: pm.response.status, detail: body.detail || JSON.stringify(body) };",
              "const template = `",
              "<style>",
              "  body { font-family: -apple-system, system-ui, sans-serif; margin: 0; padding: 20px; color: #1a1a1a; background: #fafbfc; box-sizing: border-box; }",
