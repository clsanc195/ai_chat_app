              "  <div class='row'><div class='label'>model</div><div class='val'><code>{{model}}</code></div></div>",
              "  <div class='row'><div class='label'>status</div><div class='val'><span class='badge {{status}}'>{{status}}</span></div></div>",
              "  <div class='row'><div class='label'>created_at</div><div class='val'>{{created_at}}</div></div>",
              "  <div class='stub'>⚠ This endpoint is stubbed in main.py — runs aren't persisted as first-class objects yet.</div>",
              "</div>",
              "`;",
              "pm.visualizer.set(template, body);"
