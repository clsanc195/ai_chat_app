              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "pm.test('LLM remembers Carlos', () => pm.expect(body.message.content[0].text.value.toLowerCase()).to.include('carlos'));",
              "",
              "const userMsg = JSON.parse(pm.request.body.raw).content;",
              "const assistantMsg = body.message.content[0].text.value;",
              "const data = {",
              "  user: userMsg,",
              "  assistant: assistantMsg,",
              "  threadId: body.thread_id,",
              "  runId: body.id,",
              "  model: body.model,",
              "  status: body.status,",
              "};",
              "const template = `",
              "<script src='https://cdn.jsdelivr.net/npm/marked@14/marked.min.js'></script>",
              "<style>",
              "  body { font-family: -apple-system, system-ui, sans-serif; margin: 0; padding: 16px; color: #1a1a1a; background: #f5f7fa; box-sizing: border-box; overflow-x: hidden; }",
              "  .meta { display: flex; gap: 14px; flex-wrap: wrap; font-size: 12px; color: #6a737d; margin-bottom: 18px; padding-bottom: 12px; border-bottom: 1px solid #e1e4e8; }",
              "  .meta strong { color: #1a1a1a; font-weight: 600; }",
              "  .meta code { background: white; padding: 2px 6px; border-radius: 4px; border: 1px solid #e1e4e8; font-family: 'SF Mono', Menlo, monospace; font-size: 11px; }",
              "  .badge { padding: 3px 10px; border-radius: 12px; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }",
              "  .badge.completed { background: #dcfce7; color: #14532d; }",
              "  .turn { margin-bottom: 14px; display: flex; flex-direction: column; }",
              "  .turn.user { align-items: flex-end; }",
              "  .turn.assistant { align-items: flex-start; }",
              "  .role { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6a737d; margin-bottom: 4px; }",
              "  .bubble { padding: 12px 16px; border-radius: 14px; line-height: 1.55; max-width: 70%; overflow-wrap: anywhere; font-size: 14px; box-sizing: border-box; }",
              "  .user .bubble { background: #2563eb; color: white; border-bottom-right-radius: 4px; margin-right: 8px; }",
              "  .assistant .bubble { background: white; border: 1px solid #e1e4e8; border-bottom-left-radius: 4px; }",
              "  .markdown > *:first-child { margin-top: 0; }",
              "  .markdown > *:last-child { margin-bottom: 0; }",
              "  .markdown h1 { font-size: 17px; font-weight: 700; margin: 12px 0 6px; line-height: 1.3; }",
              "  .markdown h2 { font-size: 15px; font-weight: 700; margin: 10px 0 5px; line-height: 1.3; }",
              "  .markdown h3 { font-size: 13px; font-weight: 700; margin: 8px 0 4px; line-height: 1.3; }",
              "  .markdown p { margin: 6px 0; line-height: 1.55; }",
              "  .markdown ul, .markdown ol { padding-left: 22px; margin: 6px 0; }",
              "  .markdown li { margin: 2px 0; }",
              "  .markdown li > ul, .markdown li > ol { margin: 2px 0; }",
              "  .markdown strong { font-weight: 600; }",
              "  .markdown em { font-style: italic; }",
              "  .markdown code { background: rgba(0,0,0,0.06); padding: 1px 5px; border-radius: 3px; font-family: 'SF Mono', Menlo, monospace; font-size: 0.88em; }",
              "  .markdown pre { background: #f6f8fa; color: #24292f; padding: 10px 12px; border-radius: 6px; overflow-x: auto; margin: 8px 0; font-size: 12px; }",
              "  .markdown pre code { background: transparent; padding: 0; color: inherit; font-size: 12px; }",
              "  .markdown blockquote { border-left: 3px solid #d0d7de; padding-left: 10px; color: #6a737d; margin: 8px 0; }",
              "  .markdown a { color: inherit; text-decoration: underline; }",
              "  .markdown hr { border: none; border-top: 1px solid #d0d7de; margin: 10px 0; }",
              "  .user .markdown code { background: rgba(255,255,255,0.2); color: #fff; }",
              "  .user .markdown pre { background: rgba(0,0,0,0.22); color: #fff; }",
              "  .user .markdown pre code { color: #fff; }",
              "  .user .markdown blockquote { border-left-color: rgba(255,255,255,0.5); color: rgba(255,255,255,0.9); }",
              "</style>",
              "<div class='meta'>",
              "  <span><strong>thread:</strong> <code>{{threadId}}</code></span>",
              "  <span><strong>run:</strong> <code>{{runId}}</code></span>",
              "  <span><strong>model:</strong> <code>{{model}}</code></span>",
              "  <span class='badge {{status}}'>{{status}}</span>",
              "</div>",
              "<div class='turn user'><div class='role'>user</div><div class='bubble markdown' data-md='{{user}}'></div></div>",
              "<div class='turn assistant'><div class='role'>assistant</div><div class='bubble markdown' data-md='{{assistant}}'></div></div>",
              "<script>",
              "  function render() {",
              "    const els = document.querySelectorAll('.markdown');",
              "    if (typeof marked !== 'undefined') {",
              "      marked.setOptions({ breaks: true, gfm: true });",
              "      els.forEach(el => { el.innerHTML = marked.parse(el.dataset.md || ''); });",
              "    } else {",
              "      els.forEach(el => { el.textContent = el.dataset.md || ''; el.style.whiteSpace = 'pre-wrap'; });",
              "    }",
              "  }",
              "  if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', render); } else { render(); }",
              "</script>",
              "`;",
              "pm.visualizer.set(template, data);"
            ]
          }
        }
      ]
    },
    {
      "name": "4. List messages",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/v1/threads/{{threadId}}/messages?limit=20&order=asc"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "",
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "",
              "const data = {",
              "  count: body.data.length,",
              "  messages: body.data.map(m => ({",
              "    role: m.role,",
              "    text: m.content[0].text.value,",
              "    id: m.id",
              "  }))",
              "};",
              "const template = `",
              "<script src='https://cdn.jsdelivr.net/npm/marked@14/marked.min.js'></script>",
              "<style>",
              "  body { font-family: -apple-system, system-ui, sans-serif; margin: 0; padding: 16px; color: #1a1a1a; background: #f5f7fa; box-sizing: border-box; overflow-x: hidden; }",
              "  .header { font-size: 13px; color: #6a737d; margin-bottom: 18px; padding-bottom: 12px; border-bottom: 1px solid #e1e4e8; }",
              "  .header strong { color: #1a1a1a; font-weight: 600; }",
              "  .turn { margin-bottom: 12px; display: flex; flex-direction: column; }",
              "  .turn.user { align-items: flex-end; }",
              "  .turn.assistant { align-items: flex-start; }",
              "  .role { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: #6a737d; margin-bottom: 4px; }",
              "  .bubble { padding: 12px 16px; border-radius: 14px; line-height: 1.55; max-width: 70%; overflow-wrap: anywhere; font-size: 14px; box-sizing: border-box; }",
              "  .user .bubble { background: #2563eb; color: white; border-bottom-right-radius: 4px; margin-right: 8px; }",
              "  .assistant .bubble { background: white; border: 1px solid #e1e4e8; border-bottom-left-radius: 4px; }",
              "  .id { font-size: 9px; color: #b0b6bc; margin-top: 3px; font-family: 'SF Mono', Menlo, monospace; }",
              "  .empty { text-align: center; color: #6a737d; padding: 40px; font-style: italic; }",
              "  .markdown > *:first-child { margin-top: 0; }",
              "  .markdown > *:last-child { margin-bottom: 0; }",
              "  .markdown h1 { font-size: 17px; font-weight: 700; margin: 12px 0 6px; line-height: 1.3; }",
              "  .markdown h2 { font-size: 15px; font-weight: 700; margin: 10px 0 5px; line-height: 1.3; }",
              "  .markdown h3 { font-size: 13px; font-weight: 700; margin: 8px 0 4px; line-height: 1.3; }",
              "  .markdown p { margin: 6px 0; line-height: 1.55; }",
              "  .markdown ul, .markdown ol { padding-left: 22px; margin: 6px 0; }",
              "  .markdown li { margin: 2px 0; }",
              "  .markdown li > ul, .markdown li > ol { margin: 2px 0; }",
              "  .markdown strong { font-weight: 600; }",
              "  .markdown em { font-style: italic; }",
              "  .markdown code { background: rgba(0,0,0,0.06); padding: 1px 5px; border-radius: 3px; font-family: 'SF Mono', Menlo, monospace; font-size: 0.88em; }",
              "  .markdown pre { background: #f6f8fa; color: #24292f; padding: 10px 12px; border-radius: 6px; overflow-x: auto; margin: 8px 0; font-size: 12px; }",
              "  .markdown pre code { background: transparent; padding: 0; color: inherit; font-size: 12px; }",
              "  .markdown blockquote { border-left: 3px solid #d0d7de; padding-left: 10px; color: #6a737d; margin: 8px 0; }",
              "  .markdown a { color: inherit; text-decoration: underline; }",
              "  .markdown hr { border: none; border-top: 1px solid #d0d7de; margin: 10px 0; }",
              "  .user .markdown code { background: rgba(255,255,255,0.2); color: #fff; }",
              "  .user .markdown pre { background: rgba(0,0,0,0.22); color: #fff; }",
              "  .user .markdown pre code { color: #fff; }",
              "  .user .markdown blockquote { border-left-color: rgba(255,255,255,0.5); color: rgba(255,255,255,0.9); }",
              "</style>",
              "<div class='header'><strong>{{count}}</strong> message(s) in this thread</div>",
              "{{#if count}}",
              "  {{#each messages}}",
              "  <div class='turn {{role}}'>",
              "    <div class='role'>{{role}}</div>",
              "    <div class='bubble markdown' data-md='{{text}}'></div>",
              "    <div class='id'>{{id}}</div>",
              "  </div>",
              "  {{/each}}",
              "{{else}}",
              "  <div class='empty'>No messages yet — POST a run first.</div>",
              "{{/if}}",
              "<script>",
              "  function render() {",
              "    const els = document.querySelectorAll('.markdown');",
              "    if (typeof marked !== 'undefined') {",
              "      marked.setOptions({ breaks: true, gfm: true });",
              "      els.forEach(el => { el.innerHTML = marked.parse(el.dataset.md || ''); });",
